# ===========================================
# LMS UNSIQ - Environment Configuration Template
# ===========================================
# Copy file ini ke .env dan sesuaikan nilainya

# Application
APP_NAME="LMS UNSIQ"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/project_lms
APP_TIMEZONE=Asia/Jakarta

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=lms_unsiq
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_LIFETIME=120
SESSION_SECURE=false

# Upload
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,xls,xlsx,jpg,jpeg,png,gif,mp4,zip
